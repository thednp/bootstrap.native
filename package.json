{
  "name": "bootstrap.native",
  "version": "5.1.8",
  "author": "thednp",
  "license": "MIT",
  "description": "Bootstrap components build with Typescript",
  "homepage": "https://thednp.github.io/bootstrap.native/",
  "type": "module",
  "sideEffects": false,
  "source": "./src/index.ts",
  "types": "./dist/module/index.d.cts",
  "exports": {
    ".": "./dist/module/index.js",
    "./alert": "./dist/alert.mjs",
    "./button": "./dist/button.mjs",
    "./carousel": "./dist/carousel.mjs",
    "./collapse": "./dist/collapse.mjs",
    "./dropdown": "./dist/dropdown.mjs",
    "./modal": "./dist/modal.mjs",
    "./offcanvas": "./dist/offcanvas.mjs",
    "./popover": "./dist/popover.mjs",
    "./scrollspy": "./dist/scrollspy.mjs",
    "./tab": "./dist/tab.mjs",
    "./toast": "./dist/toast.mjs",
    "./tooltip": "./dist/tooltip.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "pre-test": "pnpm clean-coverage",
    "dev": "vite --open ./docs/index-dev.html --port 8577",
    "serve": "vite --open ./docs/index.html --port 8577",
    "test": "pnpm pre-test && vitest --browser.headless",
    "test-ui": "pnpm pre-test && vitest --browser --ui",
    "clean-coverage": "rm -rf coverage .nyc_output",
    "badges": "npx -p dependency-version-badge update-badge typescript vitest vite",
    "build": "tsdown && pnpm copy-docs",
    "build-vite": "vite build",
    "build-components": "vite build --config vite.config.components.ts",
    "copy-docs": "cp dist/bootstrap-native.min.js docs/assets/js/bootstrap-native.min.js && cp dist/bootstrap-native.min.js.map docs/assets/js/bootstrap-native.min.js.map",
    "lint": "deno lint src",
    "fix:ts": "deno lint src --fix",
    "check:ts": "tsc --noEmit",
    "prepublishOnly": "pnpm update --latest && pnpm lint && deno fmt src && pnpm build && pnpm copy-docs"
  },
  "bugs": {
    "url": "https://github.com/thednp/bootstrap.native/issues"
  },
  "files": [
    "dist",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thednp/bootstrap.native.git"
  },
  "keywords": [
    "twitter-bootstrap",
    "bootstrap",
    "native",
    "typescript"
  ],
  "dependencies": {
    "@thednp/event-listener": "^2.0.14",
    "@thednp/position-observer": "^1.1.1",
    "@thednp/shorty": "^2.0.13"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "playwright": "^1.58.2",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-strip-comments": "^0.0.9",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@8.6.12",
  "engines": {
    "node": ">=16",
    "pnpm": ">=8.6.0"
  },
  "inlinedDependencies": {
    "@thednp/event-listener": "2.0.14",
    "@thednp/position-observer": "1.1.1",
    "@thednp/shorty": "2.0.13"
  }
}
